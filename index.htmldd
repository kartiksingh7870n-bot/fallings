<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fallings Dating App</title>
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <div class="app-shell">
    <header class="app-header">
      <div>
        <h1>Fallings</h1>
        <p>अपनी पसंद को स्वाइप करें, मिलान बनाएं और बात करें।</p>
      </div>
      <div class="app-badge">Beta</div>
    </header>

    <main class="layout">
      <section class="profile-pane">
        <div class="profile-card" id="profile-card">
          <div class="profile-photo" id="profile-photo"></div>
          <div class="profile-info">
            <h2 id="profile-name">Loading...</h2>
            <p id="profile-age-location"></p>
            <p id="profile-bio"></p>
            <div class="tags" id="profile-tags"></div>
          </div>
        </div>

        <div class="actions">
          <button id="dislike-btn" class="action-button dislike">नहीं</button>
          <button id="like-btn" class="action-button like">हाँ</button>
        </div>

        <div class="status-bar">
          <p id="status-message">एक प्रोफाइल देखें, लाइक या डिसलाइक करें।</p>
          <div class="progress" id="progress"></div>
        </div>
      </section>

      <aside class="panel">
        <section class="filter-panel">
          <h3>फ़िल्टर</h3>
          <label>
            लिंग
            <select id="gender-filter">
              <option value="any">कोई भी</option>
              <option value="female">महिला</option>
              <option value="male">पुरुष</option>
              <option value="nonbinary">नॉनबाइनरी</option>
            </select>
          </label>
          <label>
            रुचि
            <select id="interest-filter">
              <option value="any">कोई भी</option>
              <option value="travel">Travel</option>
              <option value="music">Music</option>
              <option value="food">Food</option>
              <option value="fitness">Fitness</option>
              <option value="books">Books</option>
              <option value="movies">Movies</option>
            </select>
          </label>
          <button id="reset-btn" class="secondary-button">रीसेट फ़िल्टर</button>
        </section>

        <section class="matches-panel">
          <h3>Matches</h3>
          <div id="matches-list" class="matches-list">
            <p class="empty-state">यहाँ मैचेज़ दिखाई देंगी।</p>
          </div>
        </section>

        <section class="chat-panel">
          <h3>मैसेज</h3>
          <div id="chat-thread" class="chat-thread">
            <p class="empty-state">मैच पर क्लिक करें और बातचीत देखें।</p>
          </div>
        </section>
      </aside>
    </main>
  </div>

  <script src="app.js"></script>
</body>
</html>
